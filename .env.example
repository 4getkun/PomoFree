# Optional: enables cross-device account sync via Supabase.
# Leave unset and the app works fully offline via localStorage — sync UI
# will just show as unavailable. To enable: create a free project at
# supabase.com, run supabase-schema.sql in its SQL editor, then set these
# to your project's URL and anon/public key (Project Settings > API).
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
